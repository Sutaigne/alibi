# Local-machine harness state (Claude Code / agents)
.claude/

# Python build / venv / caches (Python port now under dev/)
dev/python/**/__pycache__/
dev/python/**/*.pyc
dev/python/**/*.pyo
dev/python/**/*.egg-info/
dev/python/build/
dev/python/dist/
dev/python/.venv/
dev/python/venv/
dev/python/.pytest_cache/
dev/python/.mypy_cache/
dev/python/.ruff_cache/

# Editor / OS junk
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Generated scan outputs (these land on the user's Desktop in real use; the
# repo carries deliberate synthetic examples under python/examples/).
AlibiReport_*.txt
AlibiReport_*_visual.html
AlibiRigReport_*.txt
AlibiRigReport_*_visual.html

# Temp summary files written by the unified launcher
*alibi-pc.summary
*alibi-console.summary
*alibi-loldb.json
_test_*

# Release build output (produced by scripts/build-release.ps1)
dist/
