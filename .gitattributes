# Default: normalize line endings to LF in the repo, restore on checkout.
* text=auto eol=lf

# Windows scripts: keep CRLF so they run correctly from a USB stick on Windows.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
*.psm1  text eol=crlf

# Binary
*.zip   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
